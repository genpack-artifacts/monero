{
	"name":"monero",
	"packages":[
		"genpack/paravirt", "net-dns/unbound", 
		"dev-libs/boost", "net-libs/zeromq", 
		"app-crypt/mit-krb5", "dev-libs/protobuf",
		"dev-libs/libusb", "app-admin/logrotate",
		"www-servers/nginx", "dev-db/lmdb"
	],
	"use":{
		"app-misc/mime-types": "nginx",
		"sys-apps/genpack-init": "exec-guard",
	},
	"users":[
		{
			"name":"monero",
			"uid":1000,
			"home":"/var/lib/monero",
			"shell":"/sbin/nologin",
			"comment":"Monero Daemon User"
		}
	],
	"services":[]
}
